### E. Component Architecture Patterns

#### List Page
```typescript
// Responsibilities: display list, filtering, sorting, bulk actions, open dialogs
// Does NOT: contain form logic, business rules, direct HTTP calls

export class UsersListComponent {
  // Data from service — signals
  readonly users = signal<User[]>([]);
  readonly isLoading = signal(false);

  // Filter state
  readonly searchQuery = signal('');
  readonly statusFilter = signal<UserStatus | null>(null);

  // Derived — never duplicated
  readonly filteredUsers = computed(() => {
    const q = this.searchQuery().toLowerCase();
    const status = this.statusFilter();
    return this.users().filter(u =>
      (!q || u.name.toLowerCase().includes(q)) &&
      (!status || u.status === status)
    );
  });

  // Grid-compatible data shape
  readonly gridData = computed(() => this.filteredUsers());

  // Dialog state
  readonly createDialogOpen = signal(false);
  readonly deleteTargetId = signal<string | null>(null);

  private readonly usersService = inject(UsersService);

  ngOnInit(): void {
    this.isLoading.set(true);
    this.usersService.getAll()
      .pipe(takeUntilDestroyed(this.destroyRef))
      .subscribe({
        next: users => { this.users.set(users); this.isLoading.set(false); },
        error: () => this.isLoading.set(false),
      });
  }

  onUserSelect(user: User): void { /* open detail */ }
  onCreateOpen(): void { this.createDialogOpen.set(true); }
  onDeleteRequest(id: string): void { this.deleteTargetId.set(id); }
  onDeleteConfirm(): void { /* call service */ }
}
```

#### Form Component
```typescript
// Responsibilities: collect input, validate, emit result
// Does NOT: save to API (delegates to parent via output), know about list state

export class UserFormComponent {
  @Input() user: User | null = null;  // null = create mode, User = edit mode
  @Output() saved = new EventEmitter<User>();
  @Output() cancelled = new EventEmitter<void>();

  // Form state as signals
  readonly name = signal('');
  readonly email = signal('');
  readonly role = signal<UserRole>('viewer');
  readonly isSaving = signal(false);

  // Validation state
  readonly errors = signal<Partial<Record<keyof User, string>>>({});

  readonly isEditMode = computed(() => this.user !== null);

  ngOnInit(): void {
    if (this.user) {
      this.name.set(this.user.name);
      this.email.set(this.user.email);
      this.role.set(this.user.role);
    }
  }

  onSubmit(): void {
    if (!this.validate()) return;
    // emit — parent handles the service call
    this.saved.emit({ name: this.name(), email: this.email(), role: this.role() } as User);
  }

  private validate(): boolean { /* ... */ return true; }
}
```

#### Service
```typescript
// Responsibilities: HTTP, data transformation, caching
// Does NOT: hold UI state, know about component structure

@Injectable({ providedIn: 'root' })
export class UsersService {
  private readonly http = inject(HttpClient);
  private readonly baseUrl = inject(API_BASE_URL);

  getAll(): Observable<User[]> {
    return this.http.get<ApiResponse<User[]>>(`${this.baseUrl}/users`)
      .pipe(map(r => r.data));
  }

  getById(id: string): Observable<User> {
    return this.http.get<ApiResponse<User>>(`${this.baseUrl}/users/${id}`)
      .pipe(map(r => r.data));
  }

  create(payload: CreateUserPayload): Observable<User> {
    return this.http.post<ApiResponse<User>>(`${this.baseUrl}/users`, payload)
      .pipe(map(r => r.data));
  }

  update(id: string, payload: Partial<User>): Observable<User> {
    return this.http.patch<ApiResponse<User>>(`${this.baseUrl}/users/${id}`, payload)
      .pipe(map(r => r.data));
  }

  delete(id: string): Observable<void> {
    return this.http.delete<void>(`${this.baseUrl}/users/${id}`);
  }
}
```

