### G. SCSS Architecture

```scss
// styles/styles.scss — global entry point (imports only)
@import '@syncfusion/ej2/material3.css';
@import 'tokens';
@import 'typography';
@import 'breakpoints';
@import 'rtl';
@import 'syncfusion-overrides';

// Base resets
*, *::before, *::after { box-sizing: border-box; }
html { font-size: 16px; }
body { margin: 0; font-family: var(--font-family-body); }

// Screen reader only utility
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

// Skip link
.skip-link {
  position: absolute;
  inset-block-start: -40px;
  inset-inline-start: 0;
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-sf-primary);
  color: var(--color-sf-on-primary);
  z-index: 9999;
  &:focus { inset-block-start: 0; }
}
```

```scss
// styles/_breakpoints.scss
$breakpoints: (
  'mobile':  0px,
  'tablet':  600px,
  'desktop': 1024px,
  'wide':    1440px,
);

@mixin respond-to($bp) {
  @media (min-width: map-get($breakpoints, $bp)) { @content; }
}

@mixin respond-below($bp) {
  @media (max-width: calc(map-get($breakpoints, $bp) - 1px)) { @content; }
}
```

```scss
// styles/_rtl.scss — global RTL adjustments beyond Syncfusion's auto-handling
[dir="rtl"] {
  // text-align defaults
  .text-start { text-align: right; }
  .text-end   { text-align: left; }

  // Icons that need explicit flip
  .icon-directional {
    transform: scaleX(-1);
  }
}
```

