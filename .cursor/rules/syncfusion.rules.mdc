### D. Component Selector & Binding Rules

All Syncfusion Angular components use `ejs-` selectors. **Always use property binding `[prop]` — not HTML attributes.**

#### Buttons

```html
<!-- Primary action -->
<button ejs-button cssClass="e-primary" (click)="onSave()">حفظ</button>

<!-- Icon + label -->
<button ejs-button cssClass="e-primary" iconCss="e-icons e-save" iconPosition="Right">
  حفظ
</button>

<!-- Icon only -->
<button ejs-button iconCss="e-icons e-edit" [isToggle]="false"
        aria-label="تعديل" title="تعديل"></button>

<!-- Disabled -->
<button ejs-button [disabled]="isSaving()">حفظ</button>

<!-- Loading state — spinner inside button -->
<button ejs-button cssClass="e-primary" [disabled]="isSaving()">
  @if (isSaving()) { <span class="e-spinner-pane"></span> }
  حفظ
</button>

<!-- Split button -->
<ejs-splitbutton content="إجراءات" [items]="actionItems"
                 (click)="onPrimary()" (select)="onMenuSelect($event)" />

<!-- Chip list -->
<ejs-chiplist>
  <e-chips>
    <e-chip text="نشط" cssClass="e-success"></e-chip>
    <e-chip text="معلق" cssClass="e-warning"></e-chip>
  </e-chips>
</ejs-chiplist>
```

#### Inputs

```html
<!-- TextBox -->
<ejs-textbox placeholder="أدخل الاسم" floatLabelType="Auto"
             [(ngModel)]="name" />

<!-- Required with label -->
<div class="form-field">
  <label for="email">البريد الإلكتروني *</label>
  <ejs-textbox id="email" type="email" floatLabelType="Never"
               [value]="email()" (change)="email.set($event.value)" />
</div>

<!-- Multiline -->
<ejs-textbox [multiline]="true" [rows]="4" placeholder="الوصف" />

<!-- Numeric -->
<ejs-numerictextbox [min]="0" [max]="100" [step]="1" [value]="quantity()"
                    (change)="quantity.set($event.value)" />

<!-- Masked -->
<ejs-maskedtextbox mask="000-000-0000" placeholder="رقم الهاتف" />

<!-- Password -->
<ejs-textbox type="password" floatLabelType="Auto" placeholder="كلمة المرور" />

<!-- Slider -->
<ejs-slider [min]="0" [max]="100" [value]="sliderValue()"
            (change)="sliderValue.set($event.value)" />

<!-- Switch -->
<ejs-switch [checked]="isActive()" (change)="isActive.set($event.checked)" />

<!-- Checkbox -->
<ejs-checkbox label="أوافق على الشروط" [checked]="agreed()"
              (change)="agreed.set($event.checked)" />

<!-- Radio -->
<ejs-radiobutton label="يومي" value="daily" name="frequency"
                 [checked]="frequency() === 'daily'"
                 (change)="frequency.set('daily')" />

<!-- Rating -->
<ejs-rating [value]="rating()" (change)="rating.set($event.value)" />

<!-- OTP -->
<ejs-otpinput [length]="6" separator="-"
              (change)="otp.set($event.value)" />

<!-- Color picker -->
<ejs-colorpicker [value]="color()" (change)="color.set($event.value)" />

<!-- File upload -->
<ejs-uploader [multiple]="false" allowedExtensions=".pdf,.docx"
              (success)="onFileUploaded($event)" />
```

#### Dropdowns

```html
<!-- Single select -->
<ejs-dropdownlist [dataSource]="options" [fields]="{ text: 'label', value: 'id' }"
                  [value]="selectedId()" placeholder="اختر..."
                  (change)="selectedId.set($event.value)" />

<!-- With search -->
<ejs-combobox [dataSource]="options" [fields]="{ text: 'label', value: 'id' }"
              [value]="selectedId()" placeholder="ابحث أو اختر..." />

<!-- Multi-select -->
<ejs-multiselect [dataSource]="tags" [fields]="{ text: 'name', value: 'id' }"
                 [value]="selectedTags()" mode="Box" showSelectAll="true"
                 (change)="selectedTags.set($event.value)" />

<!-- Autocomplete -->
<ejs-autocomplete [dataSource]="suggestions" [fields]="{ value: 'name' }"
                  placeholder="ابحث..." (select)="onSelect($event)" />

<!-- Dropdown tree -->
<ejs-dropdowntree [fields]="treeFields" [value]="selectedNode()"
                  (change)="selectedNode.set($event.value)" />
```

#### Date & Time

```html
<!-- Date picker -->
<ejs-datepicker [value]="date()" format="dd/MM/yyyy"
                (change)="date.set($event.value)" />

<!-- Date range -->
<ejs-daterangepicker [startDate]="startDate()" [endDate]="endDate()"
                     format="dd/MM/yyyy"
                     (change)="onDateRangeChange($event)" />

<!-- DateTime -->
<ejs-datetimepicker [value]="datetime()" format="dd/MM/yyyy HH:mm"
                    (change)="datetime.set($event.value)" />

<!-- Time only -->
<ejs-timepicker [value]="time()" format="HH:mm"
                (change)="time.set($event.value)" />
```

#### Data Grid

```html
<ejs-grid
  [dataSource]="gridData()"
  [allowSorting]="true"
  [allowFiltering]="true"
  [allowPaging]="true"
  [allowResizing]="true"
  [allowReordering]="true"
  [pageSettings]="{ pageSize: 20, pageSizes: [10, 20, 50] }"
  [filterSettings]="{ type: 'Menu' }"
  [toolbar]="['Search', 'ExcelExport', 'PdfExport', 'ColumnChooser']"
  [showColumnChooser]="true"
  (toolbarClick)="onToolbarClick($event)"
>
  <e-columns>
    <e-column field="id" headerText="الرقم" width="80" isPrimaryKey="true" />
    <e-column field="name" headerText="الاسم" minWidth="120" />
    <e-column field="status" headerText="الحالة" width="120">
      <ng-template #template let-data>
        <ejs-badge [content]="data.statusLabel"
                   [cssClass]="data.statusClass" />
      </ng-template>
    </e-column>
    <e-column field="createdAt" headerText="التاريخ" width="120"
              type="date" format="dd/MM/yyyy" />
    <e-column headerText="الإجراءات" width="80" [allowSorting]="false">
      <ng-template #template let-data>
        <button ejs-button iconCss="e-icons e-more-vertical"
                aria-label="إجراءات" (click)="onRowActions($event, data)" />
      </ng-template>
    </e-column>
  </e-columns>

  <!-- Empty state template -->
  <ng-template #emptyRecordTemplate>
    <div class="grid-empty-state">
      <span class="e-icons e-table-view"></span>
      <p>لا توجد سجلات. أضف عنصراً جديداً للبدء.</p>
      <button ejs-button cssClass="e-primary" (click)="onCreate()">إضافة</button>
    </div>
  </ng-template>
